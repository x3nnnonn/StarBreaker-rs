{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StarBreaker",
  "identifier": "app.starbreaker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "StarBreaker",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFNjU0NTEwREEwNzhBNTYKUldSV2lnZmFFRVZsYm93KzEyWThLQWJidFA2YW9iVkl6Y2h5TUg3TmMrZy9MTjl4MTJ1RVV3SDUK",
      "endpoints": [
        "https://github.com/diogotr7/StarBreaker/releases/latest/download/latest.json"
      ]
    }
  }
}